# 1. Використовуємо легку версію Node.js на базі Alpine
FROM node:20-alpine

# 2. Встановлюємо робочу директорію всередині контейнера
WORKDIR /usr/src/app

# 3. КРОК ОПТИМІЗАЦІЇ: Копіюємо лише файли залежностей
# Це дозволить Docker закешувати шар з 'npm install'
COPY package*.json ./

# 4. Встановлюємо лише необхідні для production бібліотеки
# Використовуємо --omit=dev, щоб образ був легшим
RUN npm install --omit=dev

# 5. Копіюємо решту вихідного коду застосунку
COPY . .

# 6. Вказуємо порт, який прослуховує Express (згідно з твоєю 1-ю лабою — 8000)
EXPOSE 8000

# 7. Запускаємо міграцію бази даних, а потім старт сервера
# Ми використовуємо "sh -c", щоб виконати дві команди послідовно
CMD ["sh", "-c", "node migrate.js && node server.js"]
